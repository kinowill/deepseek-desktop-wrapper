{
  "name": "deepseek-desktop-wrapper",
  "version": "0.4.4",
  "description": "API-only DeepSeek desktop client built with Electron",
  "author": "Kinowill",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "lint:security": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kinowill.deepseekdesktopwrapper",
    "productName": "DeepSeek Desktop Wrapper",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/**/*",
      ".github/**/*",
      "package.json",
      "README.md",
      "CHANGELOG.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}